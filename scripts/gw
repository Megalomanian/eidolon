#!/usr/bin/env bash
# gw — eidolon orchestrator
# Subcommands wrap common pentest flows and route output into engagement dirs.

set -euo pipefail

GW_VERSION="0.1.0"
GW_STATE_DIR="${HOME}/.config/eidolon"
GW_ACTIVE_FILE="${GW_STATE_DIR}/active"
ARTIFACTS="${ARTIFACTS:-/shared}"
SECLISTS="${SECLISTS:-/opt/seclists}"
SOCKS5_HOST="${SOCKS5_HOST:-127.0.0.1}"
SOCKS5_PORT="${SOCKS5_PORT:-1080}"

c_red()   { printf '\033[1;31m%s\033[0m' "$*"; }
c_grn()   { printf '\033[1;32m%s\033[0m' "$*"; }
c_ylw()   { printf '\033[1;33m%s\033[0m' "$*"; }
c_blu()   { printf '\033[1;34m%s\033[0m' "$*"; }
c_dim()   { printf '\033[90m%s\033[0m' "$*"; }
log()     { printf '%s %s\n' "$(c_blu "[gw]")" "$*" >&2; }
warn()    { printf '%s %s\n' "$(c_ylw "[gw]")" "$*" >&2; }
die()     { printf '%s %s\n' "$(c_red "[gw]")" "$*" >&2; exit 1; }
ok()      { printf '%s %s\n' "$(c_grn "[gw]")" "$*" >&2; }
need()    { command -v "$1" >/dev/null 2>&1 || die "missing tool: $1 (rebuild image or run a variant that includes it)"; }
have()    { command -v "$1" >/dev/null 2>&1; }

ensure_state() { mkdir -p "${GW_STATE_DIR}"; }

active_engagement() {
  [ -f "${GW_ACTIVE_FILE}" ] && cat "${GW_ACTIVE_FILE}" || true
}

require_engagement() {
  local d
  d="${ENGAGEMENT_DIR:-$(active_engagement)}"
  [ -n "$d" ] && [ -d "$d" ] || die "no active engagement. run: gw new <client>"
  printf '%s' "$d"
}

# ----------------------------------------------------------------------------
# engagement
# ----------------------------------------------------------------------------
cmd_new() {
  local client="${1:-}"
  [ -n "$client" ] || die "usage: gw new <client>"
  ensure_state
  local stamp dir
  stamp="$(date -u +%Y-%m-%d_%H%M%S)"
  dir="${ARTIFACTS}/${client}/${stamp}"
  mkdir -p "${dir}"/{recon,scans,creds,loot,reports,logs}
  printf '%s' "${dir}" > "${GW_ACTIVE_FILE}"
  cat > "${dir}/engagement.yml" <<YAML
client: ${client}
started: ${stamp}
operator: $(id -un)@$(hostname)
socks: ${SOCKS5_HOST}:${SOCKS5_PORT}
variant: ${GHOST_LABEL:-unknown}
YAML
  ok "engagement: ${dir}"
  echo "${dir}"
}

cmd_use() {
  local client="${1:-}"
  [ -n "$client" ] || die "usage: gw use <client>"
  ensure_state
  local latest
  latest="$(ls -1dt "${ARTIFACTS}/${client}"/*/ 2>/dev/null | head -1 | sed 's:/$::')"
  [ -n "$latest" ] || die "no engagement found for ${client} (try: gw new ${client})"
  printf '%s' "${latest}" > "${GW_ACTIVE_FILE}"
  ok "active: ${latest}"
  echo "${latest}"
}

cmd_cd() {
  local d
  d="${ENGAGEMENT_DIR:-$(active_engagement)}"
  [ -n "$d" ] || die "no active engagement"
  echo "${d}"
}

cmd_ls() {
  ensure_state
  local active
  active="$(active_engagement)"
  printf '%-40s %s\n' "ENGAGEMENT" "ACTIVE"
  find "${ARTIFACTS}" -mindepth 2 -maxdepth 2 -type d 2>/dev/null | sort | while read -r d; do
    local marker=""
    [ "$d" = "$active" ] && marker="$(c_grn '*')"
    printf '%-40s %s\n' "$d" "$marker"
  done
}

# ----------------------------------------------------------------------------
# recon (web/dns)
# ----------------------------------------------------------------------------
cmd_recon() {
  local domain="${1:-}"
  [ -n "$domain" ] || die "usage: gw recon <domain>"
  local dir; dir="$(require_engagement)"
  local out="${dir}/recon"
  local log="${dir}/logs/recon_$(date -u +%H%M%S).log"
  mkdir -p "$out"

  log "recon: ${domain} -> ${out}"
  {
    echo "[*] subfinder"
    if have subfinder; then
      subfinder -silent -d "$domain" -all
    elif have dnsx; then
      warn "subfinder missing, using dnsx wordlist fallback"
      [ -f "${SECLISTS}/Discovery/DNS/subdomains-top1million-20000.txt" ] && \
        dnsx -silent -d "$domain" -w "${SECLISTS}/Discovery/DNS/subdomains-top1million-20000.txt" || true
    else
      warn "no subdomain tool available"
    fi
  } | tee "${out}/subs.txt" | wc -l | xargs -I{} log "subs found: {}"

  if have httpx && [ -s "${out}/subs.txt" ]; then
    log "httpx probing"
    httpx -silent -status-code -title -tech-detect -follow-redirects \
      -l "${out}/subs.txt" -o "${out}/httpx.txt" 2>>"$log" || true
  fi

  if have nuclei && [ -s "${out}/httpx.txt" ]; then
    log "nuclei (info+low+medium)"
    nuclei -silent -severity info,low,medium,high,critical \
      -l "${out}/httpx.txt" -o "${out}/nuclei.txt" 2>>"$log" || true
  fi

  ok "recon done: ${out}"
}

# ----------------------------------------------------------------------------
# web (full pipeline)
# ----------------------------------------------------------------------------
cmd_web() {
  local url="${1:-}"
  [ -n "$url" ] || die "usage: gw web <url>"
  local dir; dir="$(require_engagement)"
  local out="${dir}/scans"; mkdir -p "$out"
  local stamp; stamp="$(date -u +%H%M%S)"

  log "web: $url"
  if have httpx; then
    echo "$url" | httpx -silent -status-code -title -tech-detect -ip -tls-grab \
      > "${out}/httpx_${stamp}.txt" || true
  fi
  if have whatweb; then whatweb -a 3 "$url" > "${out}/whatweb_${stamp}.txt" 2>&1 || true; fi
  if have wafw00f; then wafw00f -a "$url" > "${out}/wafw00f_${stamp}.txt" 2>&1 || true; fi
  if have nuclei; then
    nuclei -silent -severity low,medium,high,critical -u "$url" \
      -o "${out}/nuclei_${stamp}.txt" || true
  fi
  if have nikto; then
    nikto -h "$url" -o "${out}/nikto_${stamp}.txt" -ask no -nointeractive 2>/dev/null || true
  fi
  if have gobuster; then
    local wl="${SECLISTS}/Discovery/Web-Content/common.txt"
    [ -f "$wl" ] && gobuster dir -u "$url" -w "$wl" -q -k -t 30 \
      -o "${out}/gobuster_${stamp}.txt" || true
  fi
  ok "web done: ${out}"
}

# ----------------------------------------------------------------------------
# fuzz
# ----------------------------------------------------------------------------
cmd_fuzz() {
  local url="${1:-}"
  [ -n "$url" ] || die "usage: gw fuzz <url-with-FUZZ>"
  need ffuf
  local dir; dir="$(require_engagement)"
  local out="${dir}/scans"; mkdir -p "$out"
  local stamp; stamp="$(date -u +%H%M%S)"
  local wl="${SECLISTS}/Discovery/Web-Content/directory-list-2.3-medium.txt"
  [ -f "$wl" ] || wl="${SECLISTS}/Discovery/Web-Content/common.txt"

  log "fuzz: ${url}"
  ffuf -u "$url" -w "$wl" -mc 200,204,301,302,307,401,403,405 \
    -of json -o "${out}/ffuf_${stamp}.json" -t 50 -p 0.1 || true
  ok "fuzz done: ${out}/ffuf_${stamp}.json"
}

# ----------------------------------------------------------------------------
# ad
# ----------------------------------------------------------------------------
cmd_ad() {
  local dc="${1:-}"; local user="${2:-}"; local pass="${3:-}"
  [ -n "$dc" ] || die "usage: gw ad <dc-ip> [<user> <pass>]"
  local dir; dir="$(require_engagement)"
  local out="${dir}/scans"; mkdir -p "$out"
  local creds="${dir}/creds"; mkdir -p "$creds"
  local stamp; stamp="$(date -u +%H%M%S)"

  log "ad: dc=${dc} user=${user:-<null>}"
  if have nxc; then
    if [ -n "$user" ]; then
      nxc smb "$dc" -u "$user" -p "${pass}" --shares > "${out}/nxc_smb_${stamp}.txt" 2>&1 || true
      nxc ldap "$dc" -u "$user" -p "${pass}" --users > "${out}/nxc_ldap_users_${stamp}.txt" 2>&1 || true
    else
      nxc smb "$dc" -u '' -p '' --shares > "${out}/nxc_smb_anon_${stamp}.txt" 2>&1 || true
    fi
  fi
  if have kerbrute && [ -f "${SECLISTS}/Usernames/xato-net-10-million-usernames.txt" ]; then
    kerbrute userenum -d "$(echo "$dc" | tr -d '0-9.')" --dc "$dc" \
      "${SECLISTS}/Usernames/xato-net-10-million-usernames.txt" \
      > "${out}/kerbrute_${stamp}.txt" 2>&1 || true
  fi
  if have bloodhound-python && [ -n "$user" ] && [ -n "$pass" ]; then
    log "bloodhound collection (this can take a while)"
    (cd "${out}" && bloodhound-python -d "$(echo "$dc" | tr -d '0-9.')" \
      -u "$user" -p "$pass" -ns "$dc" -c All --zip 2>&1 | tee "bloodhound_${stamp}.log") || true
  fi
  if have certipy && [ -n "$user" ] && [ -n "$pass" ]; then
    certipy find -u "$user@$(echo "$dc" | tr -d '0-9.')" -p "$pass" \
      -dc-ip "$dc" -output "${out}/certipy_${stamp}" 2>&1 | tee -a "${out}/certipy_${stamp}.log" || true
  fi
  ok "ad done: ${out}"
}

# ----------------------------------------------------------------------------
# mobile
# ----------------------------------------------------------------------------
cmd_mobile() {
  local pkg="${1:-}"
  [ -n "$pkg" ] && [ -f "$pkg" ] || die "usage: gw mobile <apk|ipa>"
  local dir; dir="$(require_engagement)"
  local out="${dir}/scans"; mkdir -p "$out"
  local stamp; stamp="$(date -u +%H%M%S)"
  local name; name="$(basename "$pkg")"
  local extract="${out}/${name%.*}_${stamp}"
  mkdir -p "$extract"

  log "mobile: ${pkg}"
  case "${pkg##*.}" in
    apk)
      have apkid    && apkid "$pkg" > "${extract}/apkid.txt" 2>&1 || true
      have aapt     && aapt dump badging "$pkg" > "${extract}/aapt.txt" 2>&1 || true
      have apktool  && apktool d -q -f -o "${extract}/apktool" "$pkg" 2>&1 || true
      have jadx     && jadx -q -d "${extract}/jadx" "$pkg" 2>&1 || true
      have mobsfscan && mobsfscan -o "${extract}/mobsfscan.txt" "${extract}/jadx" 2>&1 || true
      ;;
    ipa)
      unzip -q "$pkg" -d "${extract}/payload" || true
      have file && find "${extract}/payload" -type f -name '*.app' -exec file {} + > "${extract}/file.txt" 2>&1 || true
      ;;
    *) die "unsupported: ${pkg}" ;;
  esac
  ok "mobile done: ${extract}"
}

# ----------------------------------------------------------------------------
# wifi
# ----------------------------------------------------------------------------
cmd_wifi() {
  local iface="${1:-}"
  [ -n "$iface" ] || die "usage: gw wifi <iface>"
  need airodump-ng
  local dir; dir="$(require_engagement)"
  local out="${dir}/scans"; mkdir -p "$out"
  local stamp; stamp="$(date -u +%H%M%S)"
  local prefix="${out}/wifi_${stamp}"

  log "wifi: ${iface} -> ${prefix}"
  warn "Ctrl-C when done. Capture saved to ${prefix}*.cap"
  airodump-ng -w "$prefix" --output-format pcap "$iface"
}

# ----------------------------------------------------------------------------
# report
# ----------------------------------------------------------------------------
cmd_report() {
  local dir; dir="$(require_engagement)"
  local rep="${dir}/reports/summary_$(date -u +%Y%m%d_%H%M%S).md"
  mkdir -p "${dir}/reports"

  {
    echo "# Engagement Summary"
    echo
    [ -f "${dir}/engagement.yml" ] && cat "${dir}/engagement.yml" && echo
    echo "## Recon"
    if [ -d "${dir}/recon" ]; then
      for f in "${dir}/recon"/*.txt; do
        [ -f "$f" ] || continue
        echo
        echo "### $(basename "$f")"
        echo
        echo '```'
        head -200 "$f"
        echo '```'
      done
    fi
    echo
    echo "## Scans"
    if [ -d "${dir}/scans" ]; then
      for f in "${dir}/scans"/*; do
        [ -f "$f" ] || continue
        echo
        echo "### $(basename "$f")"
        echo
        echo '```'
        head -100 "$f"
        echo '```'
      done
    fi
    echo
    echo "## Loot"
    [ -d "${dir}/loot" ] && find "${dir}/loot" -type f | sed 's/^/  - /'
    echo
    echo "_generated $(date -u +%Y-%m-%dT%H:%M:%SZ)_"
  } > "$rep"
  ok "report: ${rep}"
}

cmd_versions() { gw-versions "$@"; }

cmd_help() {
  cat <<HELP
gw — eidolon orchestrator (v${GW_VERSION})

ENGAGEMENT
  gw new <client>             create new engagement dir under ${ARTIFACTS}
  gw use <client>              activate latest engagement for client
  gw cd                        print active engagement dir (use \$(gw cd))
  gw ls                        list all engagements

PIPELINES
  gw recon <domain>            subfinder | httpx | nuclei
  gw web <url>                 httpx + whatweb + wafw00f + nuclei + nikto + gobuster
  gw fuzz <url-with-FUZZ>      ffuf wordlist fuzz
  gw ad <dc-ip> [user pass]    nxc + kerbrute + bloodhound + certipy
  gw mobile <apk|ipa>          static analysis pipeline
  gw wifi <iface>              airodump capture

UTILITY
  gw report                    consolidate /shared/<engagement> into markdown
  gw versions [file]           print installed tool versions
  gw help                      show this help

ENV
  ENGAGEMENT_DIR               override active engagement
  SOCKS5_HOST/SOCKS5_PORT      pivot proxy (default ${SOCKS5_HOST}:${SOCKS5_PORT})
HELP
}

main() {
  local sub="${1:-help}"; shift || true
  case "$sub" in
    new)       cmd_new "$@" ;;
    use)       cmd_use "$@" ;;
    cd)        cmd_cd ;;
    ls|list)   cmd_ls ;;
    recon)     cmd_recon "$@" ;;
    web)       cmd_web "$@" ;;
    fuzz)      cmd_fuzz "$@" ;;
    ad)        cmd_ad "$@" ;;
    mobile)    cmd_mobile "$@" ;;
    wifi)      cmd_wifi "$@" ;;
    report)    cmd_report ;;
    versions)  cmd_versions "$@" ;;
    help|-h|--help) cmd_help ;;
    -V|--version)   echo "gw ${GW_VERSION}" ;;
    *) die "unknown subcommand: ${sub} (try: gw help)" ;;
  esac
}

main "$@"
