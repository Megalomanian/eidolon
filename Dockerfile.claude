# syntax=docker/dockerfile:1
# Eidolon Claude variant — adds Claude Code + DeepSeek integration on top of base
ARG BASE_IMAGE=eidolon-base:dev
FROM ${BASE_IMAGE}

USER root

# Install Node.js 22.x (required by Claude Code)
RUN set -eux; \
    curl -fsSL https://deb.nodesource.com/setup_22.x | bash -; \
    apt-get install -y --no-install-recommends nodejs; \
    rm -rf /var/lib/apt/lists/*

# Use Chinese npm mirror for faster installs
RUN npm config set registry https://registry.npmmirror.com

# Install Claude Code CLI globally
RUN npm install -g @anthropic-ai/claude-code

# Passwordless sudo for ghost user (needed for Claude Code tool use)
RUN echo 'ghost ALL=(ALL) NOPASSWD:ALL' > /etc/sudoers.d/ghost

# Disable connectivity check to api.anthropic.com (we use DeepSeek)
ENV CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1

# Pre-configure Claude Code to skip onboarding & connectivity check
RUN mkdir -p /home/ghost/.claude
COPY scripts/eidolon-claude-settings.json /home/ghost/.claude/settings.json
# Critical: without ~/.claude.json, Claude Code ignores ANTHROPIC_BASE_URL
# and does a connectivity check against api.anthropic.com (bugs #15274, #26935)
RUN echo '{"hasCompletedOnboarding":true}' > /home/ghost/.claude.json

# Copy methodology reference (available at /opt/eidolon-methodology.md)
COPY PENTEST-METHODOLOGY.md /opt/eidolon-methodology.md

# Copy Claude profile script
COPY scripts/eidolon-claude.profile.sh /etc/profile.d/eidolon-claude.sh
RUN echo '. /etc/profile.d/eidolon-claude.sh' >> /home/ghost/.bashrc

# Fix ownership of ghost home after root COPYs
RUN chown -R ghost:ghost /home/ghost

USER ghost
WORKDIR /work
VOLUME ["/shared", "/work"]

ENTRYPOINT ["/usr/bin/tini","--"]
CMD ["/bin/bash"]
